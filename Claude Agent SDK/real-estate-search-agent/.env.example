# ── Agent identity ─────────────────────────────────────────────────────────────
AGENT_SEED=your_private_agent_seed_phrase
AGENT_NAME=real_estate_agent
AGENT_NETWORK=mainnet
AGENT_MAILBOX=true

# ── Required API keys ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_claude_sdk_api_key
AGENTVERSE_API_KEY=your_agentverse_api_key

# ── Google OAuth client ────────────────────────────────────────────────────────
# Option A: paste the JSON as a single line (recommended for Docker)
GOOGLE_OAUTH_CLIENT_JSON={"installed":{"client_id":"YOUR_CLIENT_ID.apps.googleusercontent.com","project_id":"your-project","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_secret":"YOUR_CLIENT_SECRET","redirect_uris":["http://localhost"]}}

# Option B: path to a JSON file on disk
# GOOGLE_OAUTH_CLIENT_FILE=oauth_client.json

# ── Google Sheets settings (optional) ─────────────────────────────────────────
# GOOGLE_SHEET_SHARE_EMAIL=your.email@example.com
# GOOGLE_OAUTH_TOKEN_STORE_FILE=google_user_tokens.json
# GOOGLE_OAUTH_DEVICE_STORE_FILE=google_device_flows.json

# ── Stripe payments (optional — omit for free mode) ───────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_AMOUNT_CENTS=199          # Amount in cents (199 = $1.99)
# STRIPE_CURRENCY=usd
# STRIPE_RETURN_URL=https://agentverse.ai/
# STRIPE_CHECKOUT_EXPIRES_SECONDS=1800

# ── Transport (non-mailbox local only) ────────────────────────────────────────
# AGENT_PORT=8000
# AGENT_ENDPOINT=http://127.0.0.1:8000/submit
