# Required for receipt photo extraction (OpenAI Vision)
OPENAI_API_KEY=your_openai_api_key_here

# Agentverse + ASI-One (mailbox mode)
AGENT_SEED=receipt-calculator-seed-phrase-here
AGENT_MAILBOX_KEY=your_mailbox_key_here

# Optional: Agentverse storage URL (default: https://agentverse.ai)
# AGENTVERSE_URL=https://agentverse.ai

# Optional: Stripe payment (after listing receipt items, same flow as stripe-horoscope-agent)
# If set, agent requests payment before user can say "done" to start the poll.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_AMOUNT_CENTS=100
# STRIPE_CURRENCY=usd
# STRIPE_PRODUCT_NAME=Receipt / expense processing
# STRIPE_SUCCESS_URL=https://agentverse.ai/payment-success
